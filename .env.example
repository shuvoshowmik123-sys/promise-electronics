# Environment Configuration

# ---------------------------------------------------------
# Core Requirements (Always Required)
# ---------------------------------------------------------
# Production database URL (PostgreSQL)
# e.g., postgresql://user:password@localhost:5432/promise_dev
DATABASE_URL=

# Session cookie encryption secret (Must be a long, random string in production)
SESSION_SECRET=dev-secret-key-change-in-production

# ---------------------------------------------------------
# Production Requirements (Required in NODE_ENV=production)
# ---------------------------------------------------------
# ImageKit configuration for media uploads (server-side)
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint/

# ImageKit configuration (client-side, must be prefixed VITE_)
VITE_IMAGEKIT_PUBLIC_KEY=your_public_key
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint/

# Firebase (client-side)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id

# Firebase service account (server-side, for Google OAuth server verification)
# Either place the JSON file at server/firebase-service-account.json
# or set this to the base64-encoded content of the service account JSON
FIREBASE_SERVICE_ACCOUNT_BASE64=

# SMS sender ID (required for SMS.net.bd to send OTP/notifications)
SMS_SENDER_ID=PromiseElectronics

# ---------------------------------------------------------
# Optional / Runtime Overrides
# ---------------------------------------------------------
# Server Port (Defaults to 5083)
PORT=5083

# Node Environment (development, production, test)
NODE_ENV=development

# Google OAuth (optional for local dev)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------------------------------------------------------
# Phase 5: Google Drive Encrypted Backups
# ---------------------------------------------------------
# OAuth2 refresh token for Google Drive access (Server-side)
GOOGLE_REFRESH_TOKEN=your-refresh-token
# Target Drive folder ID for backup uploads
GOOGLE_DRIVE_BACKUP_FOLDER_ID=your-folder-id
# Password used to AES-256-GCM encrypt every backup (min 16 chars)
# Set on Render Dashboard → Environment → BACKUP_ENCRYPTION_PASSWORD
BACKUP_ENCRYPTION_PASSWORD=

# ---------------------------------------------------------
# Phase 3: SMS Notifications (SMS.net.bd)
# ---------------------------------------------------------
SMS_API_URL=https://api.sms.net.bd/sendsms
SMS_API_KEY=your-sms-api-key

# Google Gemini AI (for AI features)
GEMINI_API_KEY=your-gemini-api-key

# SSE Broker Backend (memory, redis)
# Default: memory
SSE_BROKER=memory

# Cache Backend (memory, redis)
# Default: memory
CACHE_BACKEND=memory

# Redis Connection URL (Required if SSE_BROKER or CACHE_BACKEND is redis)
# REDIS_URL=redis://localhost:6379
