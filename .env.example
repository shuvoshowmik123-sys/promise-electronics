# Environment Configuration

# ---------------------------------------------------------
# Core Requirements (Always Required)
# ---------------------------------------------------------
# Production database URL (PostgreSQL)
# e.g., postgresql://user:password@localhost:5432/promise_dev
DATABASE_URL=

# Session cookie encryption secret (Must be a long, random string in production)
SESSION_SECRET=dev-secret-key-change-in-production

# Staff setup links default to 30 minutes if unset. Allowed range: 5-1440 minutes.
STAFF_INVITE_EXPIRY_MINUTES=30

# ---------------------------------------------------------
# Production Requirements (Required in NODE_ENV=production)
# ---------------------------------------------------------
# ImageKit configuration for media uploads (server-side)
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint/
# Root folder prefix for all uploads — prevents mixing files from different projects on a shared account
# Default: /promise-electronics  (subfolder paths are appended, e.g. /promise-electronics/service-requests)
IMAGEKIT_FOLDER_PREFIX=/promise-electronics

# ImageKit configuration (client-side, must be prefixed VITE_)
VITE_IMAGEKIT_PUBLIC_KEY=your_public_key
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint/
# Must match the server-side IMAGEKIT_FOLDER_PREFIX above
VITE_IMAGEKIT_FOLDER_PREFIX=/promise-electronics

# Firebase (client-side)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id

# Firebase service account (server-side, for Google OAuth server verification)
# Either place the JSON file at server/firebase-service-account.json
# or set this to the base64-encoded content of the service account JSON
FIREBASE_SERVICE_ACCOUNT_BASE64=

# SMS sender ID (required for SMS.net.bd to send OTP/notifications)
SMS_SENDER_ID=PromiseElectronics

# ---------------------------------------------------------
# Optional / Runtime Overrides
# ---------------------------------------------------------
# Server Port (Defaults to 5083)
PORT=5083

# Node Environment (development, production, test)
NODE_ENV=development

# ---------------------------------------------------------
# Database Pool Tuning (Phase 27A)
# ---------------------------------------------------------
# Max simultaneous DB connections (default: 5).
# Free-tier Aiven limits to ~25 total — keep ≤10 per dyno.
DB_POOL_MAX=5

# Proactively recycle the pool after this many seconds (default: off).
# Set to ~1800 (30 min) on Render to prevent stale connections after
# an Aiven failover. The watchdog also resets the pool on ECONNRESET/ETIMEDOUT.
DB_POOL_MAX_LIFETIME_SECONDS=1800

# Force background schedulers on/off regardless of NODE_ENV.
# "false" lets you run a production dyno without schedulers (e.g. a read-only replica).
# "true" enables schedulers in local dev. Default in production is "true".
RUN_BACKGROUND_JOBS=true

# Google OAuth (optional for local dev)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------------------------------------------------------
# Phase 5: Encrypted Application Backups
# ---------------------------------------------------------
# Password used to AES-256-GCM encrypt every backup (min 16 chars)
# Set on Render Dashboard → Environment → BACKUP_ENCRYPTION_PASSWORD
BACKUP_ENCRYPTION_PASSWORD=

# Cloudflare R2 — encrypted backup transport (server-side only)
# Real values configured in Render Environment. Never commit real values.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=

# Legacy Google Drive backup credentials (retained for legacy metadata compatibility)
# OAuth2 refresh token for Google Drive access (Server-side)
GOOGLE_REFRESH_TOKEN=your-refresh-token
# Target Drive folder ID for backup uploads
GOOGLE_DRIVE_BACKUP_FOLDER_ID=your-folder-id

# ---------------------------------------------------------
# Phase 3: SMS Notifications (SMS.net.bd)
# ---------------------------------------------------------
SMS_API_URL=https://api.sms.net.bd/sendsms
SMS_API_KEY=your-sms-api-key

# Google Gemini AI (for AI features)
GEMINI_API_KEY=your-gemini-api-key

# SSE Broker Backend (memory, redis)
# Default: memory
SSE_BROKER=memory

# Cache Backend (memory, redis)
# Default: memory
CACHE_BACKEND=memory

# Redis Connection URL (Required if SSE_BROKER or CACHE_BACKEND is redis)
# REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------
# GPS Attendance Geofence (Phase 23A)
# ---------------------------------------------------------
# Office location for geofence check-in validation.
# If unset, all check-ins are stored as geofenceStatus="unverified".
# Get coordinates from Google Maps: right-click your office → "What's here?"
OFFICE_LAT=
OFFICE_LNG=
# Geofence radius in metres. Default: 200 (covers most single-building offices)
OFFICE_RADIUS_METERS=200
# Optional customer route estimates (server-only)
OPENROUTESERVICE_API_KEY=
