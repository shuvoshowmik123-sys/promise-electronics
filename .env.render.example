# ─────────────────────────────────────────────────────────────────────────────
# RENDER BACKEND ENV — paste these into Render Dashboard → Environment
# (Render reads from dashboard, NOT from this file. This is a checklist only.)
# Render bulk import: copy KEY=value lines into "Add from .env" box.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core (REQUIRED — backend crashes without these two) ---
NODE_ENV=production
SESSION_SECRET=
DATABASE_URL=
BRAIN_DATABASE_URL=

# --- Postgres parts (from your .env) ---
PGDATABASE=
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=

# --- Separation (REQUIRED for cross-origin login cookies) ---
# Set to your Vercel domain. Triggers sameSite:none + secure cookie.
FRONTEND_URL=https://www.promiseelectronics.com

# --- AI ---
GEMINI_API_KEY=
GROQ_API_KEY=

# --- WhatsApp (from Meta console) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=PromiseWA_Webhook_2026

# --- Messenger (from Meta console) ---
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=PromiseMsgr_Webhook_2026
FACEBOOK_PAGE_ID=

# --- Image upload ---
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# --- SMS ---
SMS_API_URL=https://api.sms.net.bd/sendsms
SMS_API_KEY=

# --- Cloudflare R2 (backups storage) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=promise-backups-prod

# --- Google Drive backup (optional — backup off if blank) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_BACKUP_FOLDER_ID=
BACKUP_ENCRYPTION_PASSWORD=
BACKUP_MASTER_KEY=

# --- Optional ---
EXTRA_ALLOWED_ORIGINS=
STAFF_CAPACITY_CAP=10
