    },
    "error": {
      "status": "planned",
      "pose": "holding warning diagnostic tablet"
    },
    "offline": {
      "status": "planned",
      "pose": "holding disconnected cable"
    },
    "success": {
      "status": "planned",
      "pose": "thumbs-up with completed repair tablet"
    },
    "cancelled": {
      "status": "planned",
      "pose": "gentle stop gesture with cancelled request tablet"
