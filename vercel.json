{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://promiseelectronics.com/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "buildCommand": "npx vite build",
    "outputDirectory": "dist/public",
    "framework": "vite"
}