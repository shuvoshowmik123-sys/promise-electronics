{
    "version": 2,
    "buildCommand": "npx vite build",
    "outputDirectory": "dist/public",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://promise-electronics-5r25.onrender.com/api/:path*"
        },
        {
            "source": "/health",
            "destination": "https://promise-electronics-5r25.onrender.com/health"
        },
        {
            "source": "/ready",
            "destination": "https://promise-electronics-5r25.onrender.com/ready"
        },
        {
            "source": "/((?!assets/).*)",
            "destination": "/index.html"
        }
    ]
}
